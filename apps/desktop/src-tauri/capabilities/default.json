{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main",
  "description": "Capabilities for the main window of the desktop app.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:allow-open",
    "process:allow-restart",
    "updater:allow-check",
    "updater:allow-download-and-install",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/zanganeh/aria-focus/**" }]
    }
  ]
}
